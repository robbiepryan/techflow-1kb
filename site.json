  "t": "<style>@keyframes up{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:none}}#u{padding:4rem 2rem;text-align:center;gap:2rem}h1{font-size:clamp(2.5rem,7vw,4.5rem);background:linear-gradient(135deg,#7ef8ff,#a78bfa,#f0abfc);background-size:200% 200%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:800;letter-spacing:-.03em;animation:up .8s ease both,grad 6s ease infinite}@keyframes grad{0%,100%{background-position:0% 50%}50%{background-position:100% 50%}}.sub{font-size:clamp(.9rem,2vw,1.25rem);color:rgba(255,255,255,.55);max-width:34em;line-height:1.7;margin:0 auto;animation:up .8s .15s ease both}.links{display:flex;gap:1rem;flex-wrap:wrap;justify-content:center;margin:1rem 0;animation:up .8s .3s ease both}.links a{padding:.45rem 1.1rem;border:1px solid rgba(255,255,255,.12);border-radius:2rem;font-size:.8rem;text-decoration:none;transition:all .3s;background:rgba(255,255,255,.04);letter-spacing:.03em}.links a:hover{background:rgba(120,100,255,.2);border-color:rgba(167,139,250,.5);transform:translateY(-2px);box-shadow:0 4px 20px rgba(139,92,246,.2)}h2{font-size:1.3rem;color:rgba(255,255,255,.65);font-weight:600;letter-spacing:.05em;text-transform:uppercase;animation:up .8s .4s ease both}.projects{display:grid;grid-template-columns:repeat(auto-fit,minmax(270px,1fr));gap:1.25rem;max-width:900px;width:100%;margin:1rem auto 0}.card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:1rem;padding:1.4rem;text-align:left;transition:all .4s cubic-bezier(.4,0,.2,1);animation:up .6s ease both;text-decoration:none!important}.card:nth-child(1){animation-delay:.45s}.card:nth-child(2){animation-delay:.55s}.card:nth-child(3){animation-delay:.65s}.card:nth-child(4){animation-delay:.75s}.card:nth-child(5){animation-delay:.85s}.card:nth-child(6){animation-delay:.95s}.card:hover{background:rgba(120,100,255,.08);border-color:rgba(167,139,250,.3);transform:translateY(-6px);box-shadow:0 12px 40px rgba(139,